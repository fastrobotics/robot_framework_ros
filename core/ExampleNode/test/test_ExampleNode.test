<?xml version="1.0"?>
<launch>
    <arg name="robot_namespace" value="/test" />
    <group ns="test">
        <include file="$(find robot_framework_ros)/core/ExampleNode/launch/example_node.launch">
        </include>
        <test test-name="test_exampleNode" pkg="robot_framework_ros" type="test_exampleNode"/>
    </group>
   
</launch>