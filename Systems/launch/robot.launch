<?xml version="1.0"?>
<launch>
    <arg name="robot_namespace" value="/" />
    <node pkg="rqt_plot" type="rqt_plot" name="rqt_plot" args="/cmd_throttle/linear/x /cmd_throttle/angular/z" />
    <node name="joy_node" pkg="joy" type="joy_node" output="screen" clear_params="true">
    </node>
    <include file="$(find robot_framework_ros)/Systems/Navigation/Subsystems/NavigationExecutor/Nodes/DriveExecutor/TankDriveExecutorNode/launch/tankDriveExecutor_node.launch">
            <arg name="robot_namespace" value="$(arg robot_namespace)"/>
    </include>
    <include file="$(find robot_framework_ros)/Systems/UserInterface/Subsystems/RemoteControl/Nodes/TeleopControl/BasicTeleopControlNode/launch/basicTeleopControl_node.launch">
        <arg name="robot_namespace" value="$(arg robot_namespace)"/>
    </include>
        
   
</launch>