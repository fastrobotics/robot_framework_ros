<?xml version="1.0"?>
<launch>
    <arg name="robot_namespace" value="/test" />
    <arg name="topic_command_throttle" value="cmd_throttle"/> 
    <arg name="topic_left_drive" value ="left_drive"/>
    <arg name="topic_right_drive" value="right_drive"/>
    <group ns="test">
        <include file="$(find robot_framework_ros)/Systems/Navigation/Subsystems/NavigationExecutor/Nodes/DriveExecutor/TankDriveExecutorNode/launch/tankDriveExecutor_node.launch">
            <arg name="robot_namespace" value="$(arg robot_namespace)"/>
            <!-- Input Topics -->
            <arg name="topic_command_throttle" value="$(arg topic_command_throttle)"/> 

            <!-- Output Topics -->
            <arg name="topic_left_drive" value="$(arg topic_left_drive)"/>
            <arg name="topic_right_drive" value="$(arg topic_right_drive)"/>
        </include>
        <test test-name="test_nodeTankDriveExecutor" pkg="robot_framework_ros" type="test_nodeTankDriveExecutor"/>
    </group>
   
</launch>