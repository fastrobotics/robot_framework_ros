<?xml version="1.0"?>
<launch>
<node name="nodeTankDriveExecutor" pkg="robot_framework_ros" type="nodeTankDriveExecutor"  output="screen" clear_params="true">
    <param name="loop1_rate" value="1.0" />
    <param name="loop2_rate" value="2.0" />
    <param name="loop3_rate" value="3.0" />
</node>
</launch>